{
  "name": "@cadena24-wms/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "nx run-many --targets=serve --projects=backend,frontend --parallel=2",
    "dev:backend": "nx serve backend",
    "dev:frontend": "nx serve frontend --port 4300",
    "build": "nx run-many --targets=build --projects=backend,frontend --parallel=2",
    "build:backend": "nx build backend",
    "build:frontend": "nx build frontend",
    "build:prod:backend": "nx build backend --configuration=production",
    "build:prod:frontend": "nx build frontend --configuration=production",
    "start:prod:backend": "NODE_ENV=production node dist/apps/backend/main.js",
    "test": "nx run-many --targets=test --projects=backend,frontend",
    "test:backend": "nx test backend",
    "test:frontend": "nx test frontend",
    "lint": "nx run-many --targets=lint --projects=backend,frontend",
    "lint:backend": "nx lint backend",
    "lint:frontend": "nx lint frontend",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,html,scss,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,html,scss,css}\"",
    "prisma:generate": "prisma generate --schema=apps/backend/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=apps/backend/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=apps/backend/prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=apps/backend/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=apps/backend/prisma/schema.prisma"
  },
  "private": true,
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.0",
    "@angular-devkit/core": "^21.2.0",
    "@angular-devkit/schematics": "^21.2.0",
    "@angular/build": "^21.2.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.14",
    "@nx/angular": "^22.5.3",
    "@nx/jest": "^22.5.3",
    "@nx/js": "22.5.3",
    "@nx/nest": "22.5.3",
    "@nx/web": "22.5.3",
    "@nx/webpack": "^22.5.3",
    "@nx/workspace": "22.5.3",
    "@schematics/angular": "^21.2.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/express": "^4.17.25",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@typescript-eslint/utils": "^8.40.0",
    "angular-eslint": "^21.0.1",
    "eslint": "^9.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.0.2",
    "jest-preset-angular": "~16.0.0",
    "jest-util": "^30.0.2",
    "nx": "22.5.3",
    "prettier": "^3.8.1",
    "prisma": "^6.19.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.14",
    "@nestjs/platform-express": "^11.1.14",
    "@popperjs/core": "^2.11.8",
    "@prisma/client": "^6.19.2",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "http-server": "^14.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  }
}
